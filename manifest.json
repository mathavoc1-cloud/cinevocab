{
  "manifest_version": 3,
  "name": "cinevocab",
  "version": "1.0",
  "description": "Save French subtitles from any streaming platform in one click.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "css": ["overlay.css"]
    }
  ]
}